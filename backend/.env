# MediTrace Backend — Environment Variables
# Copy this to .env and fill in your values

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_super_secret_jwt_key_here_change_this

# Database
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./meditrace.db
# Production (PostgreSQL on Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/meditrace

# App Settings
APP_NAME=MediTrace
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,https://meditrace.vercel.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
UPLOAD_LIMIT_PER_HOUR=10
AI_AGENT_LIMIT_PER_MINUTE=5
